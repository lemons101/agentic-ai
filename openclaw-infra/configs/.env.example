# ============================================================
# OpenClaw 环境变量配置文件
#
# 使用说明：
# 1. 复制本文件为 /opt/openclaw.env
# 2. 替换下方的占位值为你的真实 Key 和 Base URL
# 3. 确保文件权限为 600（chmod 600 /opt/openclaw.env）
#
# OpenClaw 使用 OpenAI 兼容格式，以下提供商均可直接使用：
# ============================================================

# ==================== 选择一个提供商，取消注释 ====================

# --- DeepSeek（国内性价比最高）---
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_BASE_URL=https://api.deepseek.com/v1

# --- 豆包（火山引擎）---
# OPENAI_API_KEY=<YOUR_DOUBAO_API_KEY>
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- 通义千问（阿里云百炼）---
# OPENAI_API_KEY=<YOUR_DASHSCOPE_API_KEY>
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Kimi（Moonshot AI）---
# OPENAI_API_KEY=<YOUR_KIMI_API_KEY>
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# --- OpenAI 官方 ---
# OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 硅基流动 ---
# OPENAI_API_KEY=<YOUR_SILICONFLOW_API_KEY>
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# ==================== openclaw.json 中引用的其他 Key ====================

# 火山引擎 Coding Plan API Key（openclaw.json → models.providers.volcengine.apiKey）
VOLCENGINE_CODING_API_KEY=<YOUR_VOLCENGINE_CODING_API_KEY>

# 火山引擎 Embedding API Key（openclaw.json → agents.defaults.memorySearch.remote.apiKey）
VOLCENGINE_EMBEDDING_API_KEY=<YOUR_VOLCENGINE_EMBEDDING_API_KEY>

# Hotai2API Key（openclaw.json → models.providers.hotai.apiKey）
HOTAI_API_KEY=<YOUR_HOTAI_API_KEY>

# OpenClaw Gateway Token（openclaw.json → gateway.auth.token）
OPENCLAW_GATEWAY_TOKEN=<YOUR_OPENCLAW_GATEWAY_TOKEN>

# 企业微信机器人 Secret（openclaw.json → channels.wecom.secret）
WECOM_BOT_SECRET=<YOUR_WECOM_BOT_SECRET>

# 飞书应用 Secret（openclaw.json → channels.feishu.appSecret）
FEISHU_APP_SECRET=<YOUR_FEISHU_APP_SECRET>
